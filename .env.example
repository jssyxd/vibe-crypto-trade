# LLM Provider Configuration
# Choose one provider and fill in the details

# DeepSeek (recommended - good value)
LANGCHAIN_PROVIDER=deepseek
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
LANGCHAIN_MODEL_NAME=deepseek/deepseek-v3.2

# Alternative: OpenAI
# LANGCHAIN_PROVIDER=openai
# OPENAI_API_KEY=your_openai_key_here
# LANGCHAIN_MODEL_NAME=gpt-4.1

# Alternative: Groq (fast, free tier available)
# LANGCHAIN_PROVIDER=groq
# GROQ_API_KEY=your_groq_key_here
# LANGCHAIN_MODEL_NAME=llama-3.1-70b-versatile

# Security
API_AUTH_KEY=change_me_to_random_string_in_production

# Optional: Tushare for A-share data
# TUSHARE_TOKEN=your_tushare_token
